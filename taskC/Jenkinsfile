pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
    }

    environment {
        REPOA_URL      = 'https://github.com/EverestPhone/grpc.git'
        REPOC_URL      = 'https://github.com/EverestPhone/doxygen-log-parser.git'
        DOXYGEN_CONFIG = 'Doxyfile'
        WARNINGS_FILE  = 'doxygen_warnings.log'
        OUTPUT_ARCHIVE = 'doc.tar.gz'
        OUTPUT_CSV     = 'doxygen_warnings.csv'
    }

    stages {

        stage('Checkout RepoA') {
            steps {
                deleteDir()
                bat """
                    @echo off
                    echo =^>^> Cloning forked grpc repository...
                    git clone --depth=1 --branch=master %REPOA_URL% repoA
                """
            }
        }

        stage('Generate Doxygen Config') {
            steps {
                bat """
                    @echo off
                    cd repoA
                    doxygen -g %DOXYGEN_CONFIG%
                """
            }
        }

        stage('Adjust Doxygen Config') {
            steps {
                bat """
                    @echo off
                    cd repoA
                    powershell -Command "(Get-Content %DOXYGEN_CONFIG%) -replace '^INPUT\\\\s*=.*', 'INPUT = src' | Set-Content %DOXYGEN_CONFIG%"
                    powershell -Command "(Get-Content %DOXYGEN_CONFIG%) -replace '^GENERATE_HTML\\\\s*=.*', 'GENERATE_HTML = YES' | Set-Content %DOXYGEN_CONFIG%"
                    powershell -Command "(Get-Content %DOXYGEN_CONFIG%) -replace '^GENERATE_LATEX\\\\s*=.*', 'GENERATE_LATEX = NO' | Set-Content %DOXYGEN_CONFIG%"
                    powershell -Command "(Get-Content %DOXYGEN_CONFIG%) -replace '^WARN_LOGFILE\\\\s*=.*', 'WARN_LOGFILE = %WARNINGS_FILE%' | Set-Content %DOXYGEN_CONFIG%"
                """
            }
        }

        stage('Run Doxygen') {
            steps {
                bat """
                    @echo off
                    cd repoA
                    doxygen %DOXYGEN_CONFIG%
                """
            }
        }

        stage('Pack Documentation') {
            steps {
                bat """
                    @echo off
                    cd repoA
                    if exist html (
                        tar -czf ../%OUTPUT_ARCHIVE% html
                    )
                """
                archiveArtifacts artifacts: "${OUTPUT_ARCHIVE}", fingerprint: true
            }
        }

        stage('Checkout RepoC') {
            steps {
                bat """
                    @echo off
                    if exist repoC rmdir /s /q repoC
                    git clone --depth=1 --branch=main %REPOC_URL% repoC
                """
            }
        }

        stage('Install Python Dependencies') {
            steps {
                bat """
                    @echo off
                    cd repoC
                    if exist requirements.txt (
                        REM Trying 'py' command which is standard for Windows
                        py -m pip install -r requirements.txt || python -m pip install -r requirements.txt
                    )
                """
            }
        }

        stage('Run Doxygen Log Parser') {
            steps {
                bat """
                    @echo off
                    setlocal enabledelayedexpansion
                    
                    set WARNINGS_PATH=repoA\\%WARNINGS_FILE%
                    set OUTPUT_PATH=%OUTPUT_CSV%

                    if exist "!WARNINGS_PATH!" (
                        echo =^>^> Found log, running parser...
                        REM Try 'py' then 'python'
                        py repoC\\doxygen_parser.py "!WARNINGS_PATH!" --output "!OUTPUT_PATH!" || python repoC\\doxygen_parser.py "!WARNINGS_PATH!" --output "!OUTPUT_PATH!"
                        
                        echo =^>^> Content of CSV:
                        if exist "!OUTPUT_PATH!" type "!OUTPUT_PATH!"
                    ) else (
                        echo ERROR: !WARNINGS_PATH! not found.
                        exit /b 1
                    )
                """
            }
        }

        stage('Archive CSV Report') {
            steps {
                // Removed allowEmptyArchive: true so that it fails if the file is missing,
                // making it easier for you to debug.
                archiveArtifacts artifacts: "${OUTPUT_CSV}", fingerprint: true
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
