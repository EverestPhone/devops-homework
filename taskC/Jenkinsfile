pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
    }

    environment {
        REPOA_URL      = 'https://github.com/EverestPhone/grpc.git'
        REPOC_URL      = 'https://github.com/EverestPhone/doxygen-log-parser.git'
        DOXYGEN_CONFIG = 'Doxyfile'
        WARNINGS_FILE  = 'doxygen_warnings.log'
        OUTPUT_ARCHIVE = 'doc.tar.gz'
        OUTPUT_CSV     = 'doxygen_warnings.csv'
    }

    stages {
        stage('Checkout RepoA') {
            steps {
                deleteDir()
                bat "git clone --depth=1 --branch=master ${REPOA_URL} repoA"
            }
        }

        stage('Generate & Adjust Doxygen Config') {
            steps {
                bat """
                    @echo off
                    cd repoA
                    echo Generating Doxyfile...
                    doxygen -g %DOXYGEN_CONFIG%
                    
                    echo Adjusting Config via PowerShell...
                    powershell -Command "(Get-Content %DOXYGEN_CONFIG%) -replace '^INPUT\\\\s*=.*', 'INPUT = src' | Set-Content %DOXYGEN_CONFIG%"
                    powershell -Command "(Get-Content %DOXYGEN_CONFIG%) -replace '^GENERATE_HTML\\\\s*=.*', 'GENERATE_HTML = YES' | Set-Content %DOXYGEN_CONFIG%"
                    powershell -Command "(Get-Content %DOXYGEN_CONFIG%) -replace '^GENERATE_LATEX\\\\s*=.*', 'GENERATE_LATEX = NO' | Set-Content %DOXYGEN_CONFIG%"
                    powershell -Command "(Get-Content %DOXYGEN_CONFIG%) -replace '^WARN_LOGFILE\\\\s*=.*', 'WARN_LOGFILE = %WARNINGS_FILE%' | Set-Content %DOXYGEN_CONFIG%"
                """
            }
        }

        stage('Run Doxygen') {
            steps {
                bat """
                    @echo off
                    cd repoA
                    doxygen %DOXYGEN_CONFIG%
                """
            }
        }

        stage('Pack & Archive Documentation') {
            steps {
                bat """
                    @echo off
                    if exist repoA\\html (
                        tar -czf %OUTPUT_ARCHIVE% -C repoA html
                    )
                """
                archiveArtifacts artifacts: "${OUTPUT_ARCHIVE}", fingerprint: true, allowEmptyArchive: true
            }
        }

        stage('Checkout Parser (RepoC)') {
            steps {
                // Remove repoC if it exists to avoid clone errors
                bat "if exist repoC rmdir /s /q repoC"
                bat "git clone --depth=1 --branch=main ${REPOC_URL} repoC"
            }
        }

        stage('Run Parser') {
            steps {
                bat """
                    @echo off
                    setlocal enabledelayedexpansion

                    REM --- Step 1: Detect Python Command ---
                    set PY_CMD=none
                    for %%i in (python.exe py.exe python3.exe) do (
                        where %%i >nul 2>nul
                        if !errorlevel! equ 0 (
                            set PY_CMD=%%i
                            goto :found
                        )
                    )
                    :found

                    if "!PY_CMD!"=="none" (
                        echo ERROR: Python not found on this Jenkins Agent. 
                        echo Please install Python and add it to the System PATH.
                        exit /b 1
                    )

                    echo Using Python command: !PY_CMD!

                    REM --- Step 2: Execute Parser ---
                    set "INPUT_LOG=repoA\\%WARNINGS_FILE%"
                    
                    if exist "!INPUT_LOG!" (
                        echo Found log file at !INPUT_LOG!. Parsing...
                        !PY_CMD! repoC\\doxygen_parser.py "!INPUT_LOG!" --output "%OUTPUT_CSV%"
                    ) else (
                        echo WARNING: No warnings log found. Creating empty CSV.
                        echo file,line,message > "%OUTPUT_CSV%"
                    )
                """
            }
        }

        stage('Archive CSV Report') {
            steps {
                archiveArtifacts artifacts: "${OUTPUT_CSV}", fingerprint: true, allowEmptyArchive: true
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed. Please check the Python installation or script logs.'
        }
        always {
            cleanWs()
        }
    }
}
