pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
    }

    environment {
        REPOA_URL      = 'https://github.com/EverestPhone/grpc.git'
        REPOC_URL      = 'https://github.com/EverestPhone/doxygen-log-parser.git'
        DOXYGEN_CONFIG = 'Doxyfile'
        WARNINGS_FILE  = 'doxygen_warnings.log'
        OUTPUT_ARCHIVE = 'doc.tar.gz'
        OUTPUT_CSV     = 'doxygen_warnings.csv'
    }

    stages {
        stage('Checkout RepoA') {
            steps {
                deleteDir()
                bat "git clone --depth=1 --branch=master %REPOA_URL% repoA"
            }
        }

        stage('Generate Doxygen Config') {
            steps {
                bat """
                    @echo off
                    cd repoA
                    doxygen -g %DOXYGEN_CONFIG%
                """
            }
        }

        stage('Adjust Doxygen Config') {
            steps {
                bat """
                    @echo off
                    cd repoA
                    powershell -Command "(Get-Content %DOXYGEN_CONFIG%) -replace '^INPUT\\\\s*=.*', 'INPUT = src' | Set-Content %DOXYGEN_CONFIG%"
                    powershell -Command "(Get-Content %DOXYGEN_CONFIG%) -replace '^GENERATE_HTML\\\\s*=.*', 'GENERATE_HTML = YES' | Set-Content %DOXYGEN_CONFIG%"
                    powershell -Command "(Get-Content %DOXYGEN_CONFIG%) -replace '^GENERATE_LATEX\\\\s*=.*', 'GENERATE_LATEX = NO' | Set-Content %DOXYGEN_CONFIG%"
                    powershell -Command "(Get-Content %DOXYGEN_CONFIG%) -replace '^WARN_LOGFILE\\\\s*=.*', 'WARN_LOGFILE = %WARNINGS_FILE%' | Set-Content %DOXYGEN_CONFIG%"
                """
            }
        }

        stage('Run Doxygen') {
            steps {
                bat """
                    @echo off
                    cd repoA
                    doxygen %DOXYGEN_CONFIG%
                """
            }
        }

        stage('Pack Documentation') {
            steps {
                bat """
                    @echo off
                    if exist repoA\\html (
                        tar -czf %OUTPUT_ARCHIVE% -C repoA html
                    )
                """
                archiveArtifacts artifacts: "${OUTPUT_ARCHIVE}", fingerprint: true, allowEmptyArchive: true
            }
        }

        stage('Checkout RepoC') {
            steps {
                bat "if exist repoC rmdir /s /q repoC"
                bat "git clone --depth=1 --branch=main %REPOC_URL% repoC"
            }
        }

        stage('Run Doxygen Log Parser') {
            steps {
                bat """
                    @echo off
                    echo Checking for log file in repoA...
                    if exist repoA\\%WARNINGS_FILE% (
                        echo Found %WARNINGS_FILE%. Attempting to run parser...
                        
                        REM Try multiple python commands in case one is not in PATH
                        py repoC\\doxygen_parser.py repoA\\%WARNINGS_FILE% --output %OUTPUT_CSV% || ^
                        python repoC\\doxygen_parser.py repoA\\%WARNINGS_FILE% --output %OUTPUT_CSV% || ^
                        python3 repoC\\doxygen_parser.py repoA\\%WARNINGS_FILE% --output %OUTPUT_CSV%
                        
                        if exist %OUTPUT_CSV% (
                            echo SUCCESS: %OUTPUT_CSV% generated.
                        ) else (
                            echo ERROR: Parser failed to create %OUTPUT_CSV%.
                            exit /b 1
                        )
                    ) else (
                        echo WARNING: No warnings log found. Creating a dummy CSV to prevent archive failure.
                        echo file,line,message > %OUTPUT_CSV%
                        echo No warnings found in Doxygen log >> %OUTPUT_CSV%
                    )
                """
            }
        }

        stage('Archive CSV Report') {
            steps {
                archiveArtifacts artifacts: "${OUTPUT_CSV}", fingerprint: true, allowEmptyArchive: true
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
